@baseUrl = localhost:8080

### 인증 흐름
# 1. createGuestAccount(또는 createAccount) → guestGuid(또는 email/password) 획득
# 2. guestLogin(또는 login) → JWT 획득 → @jwt에 입력
# 3. Game/enter (JWT 인증) → userId, token(세션 토큰) 획득 → @userId, @authToken에 입력
# 4. 이후 게임 API는 X-User-Id / X-Auth-Token 헤더로 인증

@jwt = PASTE_JWT_FROM_LOGIN_RESPONSE
@userId = PASTE_USER_ID_FROM_GAME_ENTER_RESPONSE
@authToken = PASTE_TOKEN_FROM_GAME_ENTER_RESPONSE

### Create Guest Account
POST {{baseUrl}}/Account/createGuestAccount
Content-Type: application/json

{
}

### Guest Login (응답 data = JWT)
POST {{baseUrl}}/Login/guestLogin
Content-Type: application/json

{
    "guestGuid": "4a66edaf-0ad1-4344-b486-538ef1b58c87"
}

### Create Account
POST {{baseUrl}}/Account/createAccount
Content-Type: application/json

{
    "email": "123@123.com",
    "password": "123"
}

### Login (응답 data = JWT)
POST {{baseUrl}}/Login/login
Content-Type: application/json

{
    "email": "123@123.com",
    "password": "123"
}

### Game Entry (JWT 인증, 응답 data = { userId, token })
POST {{baseUrl}}/Game/enter
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
}

### Update Nickname (세션 인증)
POST {{baseUrl}}/User/nickname
Content-Type: application/json
X-User-Id: {{userId}}
X-Auth-Token: {{authToken}}

{
    "nickname": "새로운닉네임"
}

### Character Gacha (세션 인증)
POST {{baseUrl}}/Character/gacha
Content-Type: application/json
X-User-Id: {{userId}}
X-Auth-Token: {{authToken}}

{
    "gachaType": 1,
    "count": 1
}

### Owned Characters (세션 인증)
GET {{baseUrl}}/Character/owned
X-User-Id: {{userId}}
X-Auth-Token: {{authToken}}
